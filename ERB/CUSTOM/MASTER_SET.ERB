@ANATA_SET
CALL KAIGYO
PRINTL ★★本轮主角默认为曹操，可修改初始姓名与性别★★

; 先清理会重复设定的基础素质
TALENT:MASTER:0 = 0
TALENT:MASTER:100 = 0
TALENT:MASTER:109 = 0
TALENT:MASTER:111 = 0
TALENT:MASTER:113 = 0
TALENT:MASTER:115 = 0
TALENT:MASTER:116 = 0
TALENT:MASTER:140 = 0
TALENT:MASTER:160 = 0
TALENT:MASTER:163 = 0

CSTR:MASTER:4 = 曹
CSTR:MASTER:5 = 操
NAME:MASTER = 曹操
CALLNAME:MASTER = 曹操

$INPUT_LOOP_GENDER
PRINTL
PRINTL ★★请选择主角性别★★
PRINTFORML 　[0] 男性
PRINTFORML 　[1] 女性
INPUT
IF RESULT == 0
	TALENT:MASTER:140 = 1
ELSEIF RESULT == 1
	TALENT:MASTER:163 = 1
ELSE
	GOTO INPUT_LOOP_GENDER
ENDIF

$INPUT_LOOP_NAME
PRINTL
PRINTL ★★是否修改主角初始姓名？★★
PRINTFORML 　[0] 使用默认姓名「曹操」
PRINTFORML 　[1] 自定义姓名
INPUT
IF RESULT == 0
	CSTR:MASTER:4 = 曹
	CSTR:MASTER:5 = 操
	NAME:MASTER = 曹操
	CALLNAME:MASTER = 曹操
ELSEIF RESULT == 1
	PRINTL ★★请输入主角的姓氏★★
	INPUTS
	SIF !STRLENS(RESULTS)
		GOTO INPUT_LOOP_NAME
	CSTR:MASTER:4 = %RESULTS%
	PRINTL ★★请输入主角的名字★★
	INPUTS
	SIF !STRLENS(RESULTS)
		GOTO INPUT_LOOP_NAME
	CSTR:MASTER:5 = %RESULTS%
	PRINTL
	PRINTL ★★请选择主角姓名的表现方式★★
	PRINTFORML [0] %CSTR:MASTER:4%%CSTR:MASTER:5%（东洋系）
	PRINTFORML [1] %CSTR:MASTER:5%・%CSTR:MASTER:4%（西洋系）
	$INPUT_LOOP_NAME_STYLE
	INPUT
	IF RESULT == 0
		NAME:MASTER = %CSTR:MASTER:4%%CSTR:MASTER:5%
	ELSEIF RESULT == 1
		NAME:MASTER = %CSTR:MASTER:5%・%CSTR:MASTER:4%
	ELSE
		GOTO INPUT_LOOP_NAME_STYLE
	ENDIF
	PRINTL
	PRINTL 主角在文中该如何称呼呢？
	PRINTFORML 　[0] %CSTR:MASTER:4%
	PRINTFORML 　[1] %CSTR:MASTER:5%
	PRINTFORML 　[2] %NAME:MASTER%
	$INPUT_LOOP_CALLNAME
	INPUT
	IF RESULT == 0
		CALLNAME:MASTER = %CSTR:MASTER:4%
	ELSEIF RESULT == 1
		CALLNAME:MASTER = %CSTR:MASTER:5%
	ELSEIF RESULT == 2
		CALLNAME:MASTER = %NAME:MASTER%
	ELSE
		GOTO INPUT_LOOP_CALLNAME
	ENDIF
ELSE
	GOTO INPUT_LOOP_NAME
ENDIF

PRINTFORML 主角姓名设定为「%NAME:MASTER%」
PRINTFORML 文中称呼设定为「%CALLNAME:MASTER%」

PRINTL
PRINTL ★★请选择主角的设定★★
IF TALENT:MASTER:140
	PRINTFORML 　[0] 非童贞
	PRINTFORML 　[1] 童贞
ELSE
	PRINTFORML 　[0] 非处女
	PRINTFORML 　[1] 处女
ENDIF
$INPUT_LOOP_V
INPUT
IF RESULT == 0
	IF TALENT:MASTER:140
		TALENT:MASTER:160 = 0
	ELSE
		TALENT:MASTER:0 = 0
	ENDIF
ELSEIF RESULT == 1
	IF TALENT:MASTER:140
		TALENT:MASTER:160 = 1
	ELSE
		TALENT:MASTER:0 = 1
	ENDIF
ELSE
	GOTO INPUT_LOOP_V
ENDIF

IF TALENT:MASTER:140 == 0
	PRINTL
	PRINTL ★★你的胸有多大呢？★★
	PRINTFORML 　[0] 贫乳
	PRINTFORML 　[1] 普通
	PRINTFORML 　[2] 巨乳
	$INPUT_LOOP_B
	INPUT
	IF RESULT == 0
		TALENT:MASTER:109 = 1
	ELSEIF RESULT == 1
	ELSEIF RESULT == 2
		TALENT:MASTER:111 = 1
	ELSE
		GOTO INPUT_LOOP_B
	ENDIF
ENDIF

IF TALENT:MASTER:140 == 1
	PRINTL
	PRINTL ★★你的【哔——】有多大呢？★★
	PRINTFORML 　[0] 有些短小的尺寸
	PRINTFORML 　[1] 普通男人的尺寸
	PRINTFORML 　[2] 令人羡慕的巨根
	$INPUT_LOOP_J
	INPUT
	IF RESULT == 0
		TALENT:MASTER:115 = 1
	ELSEIF RESULT == 1
	ELSEIF RESULT == 2
		TALENT:MASTER:116 = 1
	ELSE
		GOTO INPUT_LOOP_J
	ENDIF
ENDIF

PRINTL
PRINTL ★★体型是什么样子呢？★★
PRINTFORML 　[0] 矮小的体型
PRINTFORML 　[1] 普通的体型
PRINTFORML 　[2] 高大的体型
$INPUT_LOOP_K
INPUT
IF RESULT == 0
	TALENT:MASTER:100 = 1
ELSEIF RESULT == 1
ELSEIF RESULT == 2
	TALENT:MASTER:113 = 1
ELSE
	GOTO INPUT_LOOP_K
ENDIF

PRINTL ★★请选择游戏中的视角设定★★
PRINTL ※视角设定以后还可以在游戏设置中变更哦
PRINTL （现在主角在文中的称呼是用自称还是名字呢）
PRINTL
PRINTFORML 　[0] 一人称视点
PRINTFORML 　[1] 三人称视点
$INPUT_LOOP_SITEN
INPUT
IF RESULT == 0
	FLAG:3 = 1
ELSEIF RESULT == 1
	FLAG:3 = 0
ELSE
	GOTO INPUT_LOOP_SITEN
ENDIF

$INPUT_LOOP_WATASHI
PRINTL ★★主角的第一人称设定是什么？★★
PRINTL ※第一人称以后还可以在游戏设置中变更哦
PRINTL
IF TALENT:MASTER:140
	PRINTL 　[0] 吾
ELSE
	PRINTL 　[0] 吾
ENDIF
PRINTL 　[1] --自己输入--
INPUT
IF RESULT == 0
	IF TALENT:MASTER:140
		CSTR:MASTER:0 = 吾
	ELSE
		CSTR:MASTER:0 = 吾
	ENDIF
ELSEIF RESULT == 1
	INPUTS
	CSTR:MASTER:0 = %RESULTS%
ELSE
	GOTO INPUT_LOOP_WATASHI
ENDIF
PRINTFORML 主人公的第一人称是「%CSTR:MASTER:0%」，可以吗？
PRINTL
PRINTL 　[0] 是
PRINTL 　[1] 否
$INPUT_LOOP_WATASI2
INPUT
SIF RESULT != 0 && RESULT != 1
	GOTO INPUT_LOOP_WATASI2
SIF RESULT == 1
	GOTO INPUT_LOOP_WATASHI
