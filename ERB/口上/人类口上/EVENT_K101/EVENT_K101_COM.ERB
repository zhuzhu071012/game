;@KOJO_MESSAGE_COM関係
;指令実行時に出力されます
;口上を追加しない指令は無記入でも構いません
;--------------------------------------------------

@KOJO_MESSAGE_COM_K101
;助手が调教した時に口上をスキップする（好みに応じて使う、行頭の;を消すとスキップするようになる）
;SIF ASSI > 0 && ASSIPLAY
;	RETURN 0
;口塞球着用か触手口辱中、崩溃中は地の文を表示して口上をスキップする
IF (TEQUIP:20 && SELECTCOM != 107) || (TEQUIP:36 && SELECTCOM != 168) || TALENT:崩溃
	CALL TRAIN_MESSAGE
	SIF TFLAG:51 == 0 && FLAG:10 == 1
		CALL PANT_VOICE2(10)
	RETURN 0
ENDIF
;-------------------------------------------------
;指令実行時のセリフ CFLAG 300～500
;-------------------------------------------------
;=================================================
;爱抚系指令
;=================================================
;-------------------------------------------------
;0,爱抚(触手プ雷の場合を除く)
;-------------------------------------------------
IF SELECTCOM == 0 && TEQUIP:触手 == 0
	;T:XXXは今回の调教で、この指令を実行した回数。
	;调教结束時に对応するCFLAG:XXX（このキャラでこの指令の合計実行回数）に加算します。
	T:300 += 1
	;共通の地の文（EVENT_M_COM）と汎用状況説明文の呼び出し。必要ない時は消していい。
	CALL TRAIN_MESSAGE
	;今回は汎用状況説明文を表示させたくない場合：共通の地の文を呼び出す前にTFLAG:52 = 1と付け加える
	IF T:300 == 1
		;初めてこの指令を選んだ時＆感度がまだ低く、痛くない＆未陷落
		IF CFLAG:300 == 0 && C:4 <= 1 && D == 0 && !KANRAKU(TARGET)
			PRINTFORML 「住手……%CSTR:3%难道不知，随意轻薄他人之躯，是何等失礼之举么？」
			PRINTFORMW %CALLNAME%下意识绷紧了身体。
			RETURN 0
		;もう選んだことあるが、今回の调教では初めてこの指令を選んだ時
		ELSE
			IF (TALENT:恋慕 || TALENT:相亲相爱)
				PRINTFORML 「……若只是想这样碰一碰，倒也不必每次都像在试探在下的底线。」
				PRINTFORMW 「不过，若是您……在下会忍着不躲开的。」
				RETURN 0
			ELSEIF (TALENT:淫乱 || TALENT:娼妇)
			ELSEIF (TALENT:服从 || TALENT:隶属)
			;未陷落
			ELSE
				;痛くて感じる余裕が無い（AかVに装着系がある）&受虐狂ではない
				IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3 && D != 2	
					;PRINTFORML
					;RETURN 0
				ELSEIF C:4 == 1 || (C:4 == 2 && ((PALAM_COMPARE(0) && C:0 > 0) || ((PALAM:3 + UP:3) >= (PALAM:1 + UP:1) && (PALAM:3 + UP:3) >= (PALAM:2 + UP:2) && (PALAM:3 + UP:3) >= (PALAM:0 + UP:0) && C:3 > 0))) && D == 0
					;殆どか、あまり感じていない､反抗刻印 < 3　屈服刻印 < 3
					IF (PALAM:0 + UP:0) < 500 && (PALAM:0 + UP:0) < 500 && MARK:反抗刻印 < 3 && MARK:屈服刻印 < 3
						PRINTFORML 「……若%CSTR:3%以为这种触碰便能轻易动摇在下，未免太过看轻人了。」
						RETURN 0
					;Cで少し感じ始めたか、感じてきている
					ELSEIF ((PALAM:0 + UP:0) >= 500 && (PALAM:0 + UP:0) < 3000) && (PALAM:0 + UP:0) >= (PALAM:3 + UP:3)
						;PRINTFORML
						;RETURN 0
					;Cで感じている
					ELSEIF (PALAM:0 + UP:0) >= 3000 && (PALAM:0 + UP:0) >= (PALAM:3 + UP:3)
						;PRINTFORML
						;RETURN 0
					;Bで少し感じ始めたか、感じてきている
					ELSEIF  (PALAM:3 + UP:3) >= 500 && (PALAM:3 + UP:3) < 3000
						;PRINTFORML
						;RETURN 0
					;Bで感じている
					ELSE
						;PRINTFORML
						;RETURN 0
					ENDIF
				;Ｃだけ绝顶寸前
				ELSEIF C:0 == 4 && C:1 < 4 && C:2 < 4 && C:3 < 4 && D == 0
					IF MARK:反抗刻印 == 3
						;PRINTFORML
						;RETURN 0
					ELSE
						;PRINTFORML
						;RETURN 0
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	;今回の调教で二回目以降　([T:XXX < 3]というように条件を付け加えると、二回目は出るが三回目以降は出ない)
	ELSEIF T:300 < 3 || FLAG:7 == 2
	ENDIF
ENDIF

;-------------------------------------------------
;1,舔阴
;-------------------------------------------------
IF SELECTCOM == 1
	T:301 += 1
	CALL TRAIN_MESSAGE
ENDIF
;-------------------------------------------------
;2,口交
;-------------------------------------------------
IF SELECTCOM == 2
	T:302 += 1
	;共通の地の文（EVENT_M_COM）と汎用状況説明文の呼び出し。必要ない時は消していい。
	CALL TRAIN_MESSAGE
	;今回は汎用状況説明文を表示させたくない場合：共通の地の文を呼び出す前にTFLAG:52 = 1と付け加える
	IF T:302 == 1
		;初めてこの指令を選んだ時
		IF CFLAG:302 == 0
			PRINTFORML 「竟以口舌侍奉……%CSTR:3%当真不顾纲常伦理了吗？」
			PRINTFORMW %CALLNAME%说完这句话后，难掩屈辱地别开了目光。
			RETURN 0
		;もう選んだことあるが、今回の调教では初めてこの指令を選んだ時
		ELSE
			IF TALENT:恋慕 || TALENT:相亲相爱
				PRINTFORML 「……请别那样盯着看。在下会照做，只是……容在下稍稍整顿一下心绪。」
				RETURN 0
			ENDIF
			;Ｃ系用　現在のパラで口上を分岐する
			;痛くて感じる余裕が無い&受虐狂ではない
			IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
			;Ｃ責めメインの時
			ELSEIF C:4 == 1 || (C:4 == 2 && PALAM_COMPARE(0) && C:0 > 0) && D == 0
				;殆どか、あまり感じていない
				IF (PALAM:0 + UP:0) < 500
				;少し感じ始めたか、感じてきている
				ELSEIF (PALAM:0 + UP:0) < 3000
				;感じている
				ELSE
				ENDIF
			;Ｃだけ绝顶寸前
			ELSEIF C:0 == 4 && C:1 < 4 && C:2 < 4 && C:3 < 4 && D == 0
			ENDIF
		ENDIF
	;今回の调教で二回目以降
	ELSEIF T:302 < 3 || FLAG:7 == 2
	ENDIF
ENDIF

;-------------------------------------------------
;3,手指插入
;-------------------------------------------------
IF SELECTCOM == 3
	T:303 += 1
	CALL TRAIN_MESSAGE
	IF T:303 == 1
		IF CFLAG:303 == 0
			PRINTFORMW 「%CSTR:3%总爱先以这种看似温和的方式探路，可在下并不觉得这比直截了当仁慈多少。」
			PRINTFORMW 「毕竟，被人一点点剥去余裕，本就是更磨人的折辱。」
			CFLAG:303 = 1
		ELSE
			PRINTFORML 「……别故意在那处反复拨弄。」
			PRINTFORMW 「在下虽还能忍，可若连呼吸都乱了，失仪的终究还是在下。」
		ENDIF
	ELSEIF T:303 < 3 || FLAG:7 == 2
		PRINTFORML 「%CSTR:3%的手法，倒是比最初更懂得如何叫人为难了。」
		PRINTFORMW 「明知何处最易动摇，却偏要慢条斯理地逼人失守……实在恶劣。」
	ENDIF
ENDIF
;-------------------------------------------------
;4,舔肛
;-------------------------------------------------
IF SELECTCOM == 4
	T:304 += 1
	;共通の地の文（EVENT_M_COM）と汎用状況説明文の呼び出し。必要ない時は消していい。
	CALL TRAIN_MESSAGE
	;今回は汎用状況説明文を表示させたくない場合：共通の地の文を呼び出す前にTFLAG:52 = 1と付け加える
	IF T:304 == 1
		;初めてこの指令を選んだ時
		IF CFLAG:304 == 0
			PRINTFORML 「……住、住口！」
			PRINTFORMW %CALLNAME%猛地绷紧腰身，声音因震惊而发颤。
			CFLAG:304 = 1
			RETURN 0
		;もう選んだことあるが、今回の调教では初めてこの指令を選んだ時
		ELSE
			;舔肛用　現在のパラで口上を分岐する
			;痛くて感じる余裕が無い&受虐狂ではない
			IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
				PRINTFORML 「……别在这种时候还做这等多余之事。」
				PRINTFORMW 「疼痛尚且未消，%CSTR:3%却还要在下连羞耻一并咽下么？」
			;Ａ責めメインの時
			ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:2 + UP:2) >= (PALAM:1 + UP:1) && (PALAM:2 + UP:2) >= (PALAM:3 + UP:3) && (PALAM:2 + UP:2) >= (PALAM:0 + UP:0) && C:2 > 0) && D == 0
				;殆どか、あまり感じていない
				IF (PALAM:2 + UP:2) < 500
					PRINTFORML 「……别以为换了种羞辱法子，便能叫在下轻易失态。」
				;少し感じ始めたか、感じてきている
				ELSEIF (PALAM:2 + UP:2) < 3000
					PRINTFORML 「唔……%CSTR:3%、故意的么……专挑这种让人无从招架的地方……」
				;感じている
				ELSE
					PRINTFORML 「……够了，别再那样舔弄……再继续下去，在下当真要连声音都守不住了……」
				ENDIF
			;Ａだけ绝顶寸前
			ELSEIF C:2 == 4 && C:1 < 4 && C:3 < 4 && C:0 < 4 && D == 0
				PRINTFORML 「停、停下……那里若再被您这样对待，在下便要当真失控了……！」
			ENDIF
		ENDIF
	;今回の调教で二回目以降
	ELSEIF T:304 < 3 || FLAG:7 == 2
		;舔肛用　現在のパラで口上を分岐する
		;痛くて感じる余裕が無い&受虐狂ではない
		IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
			PRINTFORML 「……真亏%CSTR:3%能把这种事做得如此理直气壮。」
		;Ａ責めメインの時
		ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:2 + UP:2) >= (PALAM:1 + UP:1) && (PALAM:2 + UP:2) >= (PALAM:3 + UP:3) && (PALAM:2 + UP:2) >= (PALAM:0 + UP:0) && C:2 > 0) && D == 0
			;殆どか、あまり感じていない
			IF (PALAM:2 + UP:2) < 500
				PRINTFORML 「……够了，在下并未堕落到会对这种羞辱心怀期待。」
			;少し感じ始めたか、感じてきている
			ELSEIF (PALAM:2 + UP:2) < 3000
				PRINTFORML 「唔……别、别那样慢慢来……越是如此，越叫人难堪……」
			;感じている
			ELSE
				PRINTFORML 「……哈啊……%CSTR:3%若再不收手，在下怕是真要把廉耻二字全忘了……」
			ENDIF
		;Ａだけ绝顶寸前
		ELSEIF C:2 == 4 && C:1 < 4 && C:3 < 4 && C:0 < 4 && D == 0
			PRINTFORML 「别、别偏挑这种时候……在下会……会当场失态的……！」
		ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;5,肛门爱抚
;-------------------------------------------------
IF SELECTCOM == 5
	T:305 += 1
	;共通の地の文（EVENT_M_COM）と汎用状況説明文の呼び出し。必要ない時は消していい。
	CALL TRAIN_MESSAGE
	;今回は汎用状況説明文を表示させたくない場合：共通の地の文を呼び出す前にTFLAG:52 = 1と付け加える
	IF T:305 == 1
		;初めてこの指令を選んだ時
		IF CFLAG:305 == 0
			PRINTFORML 「......停下!」
			PRINTFORML	%CALLNAME%挣扎着向前爬去。
			CFLAG:305 = 1
			RETURN 0
		;もう選んだことあるが、今回の调教では初めてこの指令を選んだ時
		ELSE
			;Ａ系用　現在のパラで口上を分岐する
			;Ａ以外のところが痛くて感じる余裕が無い&受虐狂ではない
			IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3 && D:1 == 0
				PRINTFORML 「……别硬来。那里受的罪已够多了，%CSTR:3%还嫌不够么。」
			;Ａ責めメインの時
			ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:2 + UP:2) >= (PALAM:1 + UP:1) && (PALAM:2 + UP:2) >= (PALAM:3 + UP:3) && (PALAM:2 + UP:2) >= (PALAM:0 + UP:0) && C:2 > 0) && D <= 1
				;经验が足りなくてとにかくかなり痛い
				IF EXP:Ａ经验 < 10 && (PALAM:2 + UP:2) < 3000 || (EXP:Ａ经验 < 30 && (PALAM:2 + UP:2) < 1500)
					PRINTFORML 「唔……！荒唐，这种地方本就不是该被这样摆弄的！」
				;段々痛くなくなるが、最初はまだ痛む
				ELSEIF EXP:Ａ经验 >= 30 && EXP:Ａ经验 < 75 && (PALAM:2 + UP:2) < 500
					PRINTFORML 「……虽不似最初那般难捱，却仍叫人浑身不自在。」
				;痛くもなく感じてもない。慣れてきた。
				ELSEIF (PALAM:2 + UP:2) < 500
					PRINTFORML 「……%CSTR:3%的手，未免太熟门熟路了些。」
				;疼痛以外の何かを感じている
				ELSEIF (PALAM:2 + UP:2) < 1500
					PRINTFORML 「……不，只是发热而已，并非在愉悦……至少不该是。」
				;疼痛ながら感じている
				ELSEIF (PALAM:2 + UP:2) < 3000 && EXP:Ａ经验 < 75
					PRINTFORML 「唔……可恶，竟连疼痛里都被您逼出了别的感觉……」
				;感じている
				ELSEIF (PALAM:2 + UP:2) < 3000
					PRINTFORML 「……那里，竟也会被您调弄到这般地步……实在荒唐。」
				;後ろで明らかに感じている
				ELSEIF (PALAM:2 + UP:2) < 6000
					PRINTFORML 「哈啊……别太得意，%CSTR:3%不过是恰好捏住了在下最难堪的弱处。」
				;快感に震えている
				ELSEIF (PALAM:2 + UP:2) < 8000
					PRINTFORML 「……够了，快些停下……再这样下去，在下便要彻底乱了分寸……」
				ENDIF
			;Ａだけ绝顶寸前
			ELSEIF C:2 == 4 && C:1 < 4 && C:3 < 4 && C:0 < 4 && D == 0
				PRINTFORML 「不成……后面若再被您这样抚弄，在下便要……！」
			ENDIF
		ENDIF
	;今回の调教で二回目以降
	ELSEIF T:305 < 3 || FLAG:7 == 2
		;Ａ系用　現在のパラで口上を分岐する
		;Ａ以外のところが痛くて感じる余裕が無い&受虐狂ではない
		IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3 && D:1 == 0
			PRINTFORML 「……这种折腾，真不知%CSTR:3%究竟是图什么。」
		;Ａ責めメインの時
		ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:2 + UP:2) >= (PALAM:1 + UP:1) && (PALAM:2 + UP:2) >= (PALAM:3 + UP:3) && (PALAM:2 + UP:2) >= (PALAM:0 + UP:0) && C:2 > 0) && D <= 1
			;经验が足りなくてとにかくかなり痛い
			IF EXP:Ａ经验 < 10 && (PALAM:2 + UP:2) < 3000 || (EXP:Ａ经验 < 30 && (PALAM:2 + UP:2) < 1500)
				PRINTFORML 「唔……别再往里了，那里还远未习惯这般对待。」
			;段々痛くなくなるが、最初はまだ痛む
			ELSEIF EXP:Ａ经验 >= 30 && EXP:Ａ经验 < 75 && (PALAM:2 + UP:2) < 500
				PRINTFORML 「……虽能忍住，可那种异样感仍叫人难以安心。」
			;痛くもなく感じてもない。慣れてきた。
			ELSEIF (PALAM:2 + UP:2) < 500
				PRINTFORML 「……%CSTR:3%还真是对这处格外偏爱。」
			;疼痛以外の何かを感じている
			ELSEIF (PALAM:2 + UP:2) < 1500
				PRINTFORML 「唔……别那样磨，在下会错把这种异样当成快感的……」
			;疼痛ながら感じている
			ELSEIF (PALAM:2 + UP:2) < 3000 && EXP:Ａ经验 < 75
				PRINTFORML 「……可恶，明明还痛，却偏偏也会被逼得发热……」
			;感じている
			ELSEIF (PALAM:2 + UP:2) < 3000
				PRINTFORML 「哈……啊……后面那处，竟也会如此听您的摆布……」
			;後ろで明らかに感じている
			ELSEIF (PALAM:2 + UP:2) < 6000
				PRINTFORML 「……%CSTR:3%若见了在下这副样子，想必很是满意吧。」
			;快感に震えている
			ELSEIF (PALAM:2 + UP:2) < 8000
				PRINTFORML 「不、不要再这样细细揉弄……在下真的会……失守的……！」
			ENDIF
		;Ａだけ绝顶寸前
		ELSEIF C:2 == 4 && C:1 < 4 && C:3 < 4 && C:0 < 4 && D == 0
			PRINTFORML 「停下……！后面已经、已经要被您逼到极限了……！」
		ENDIF
	ENDIF
ENDIF
;-------------------------------------------------
;6,揉胸
;-------------------------------------------------
IF SELECTCOM == 6
	T:306 += 1
	CALL TRAIN_MESSAGE
	IF T:306 == 1
		;初めて
		IF CFLAG:306 == 0
			PRINTFORML 「……胸前也不肯放过么。」
			PRINTFORMW 「%CSTR:3%这般堂而皇之地揉弄旁人身体，倒真像是在翻阅什么供您取乐的卷宗。」
			CFLAG:306 = 1
			RETURN 0
		;今回の调教で初めて
		ELSE
			;Ｂ系用　現在のパラで口上を分岐する
			;痛くて感じる余裕が無い&受虐狂ではない
			IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
				PRINTFORML 「……痛感未消，别再胡乱按揉。」
			;Ｂ責めメインの時
			ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:3 + UP:3) >= (PALAM:1 + UP:1) && (PALAM:3 + UP:3) >= (PALAM:2 + UP:2) && (PALAM:3 + UP:3) >= (PALAM:0 + UP:0) && C:3 > 0) && D == 0
				;殆どか、あまり感じていない
				IF (PALAM:3 + UP:3) < 500
					PRINTFORML 「……这种地方，原也不该叫您这般反复把玩。」
				;少し感じ始めたか、感じてきている
				ELSEIF (PALAM:3 + UP:3) < 3000
					PRINTFORML 「唔……别揉得那样慢，越慢越叫人无法装作若无其事。」
				;感じている
				ELSE
					PRINTFORML 「……哈啊……胸口发热成这样，倒像是连呼吸都要被您拿去了。」
				ENDIF
			;Ｂだけ绝顶寸前
			ELSEIF C:3 == 4 && C:1 < 4 && C:2 < 4 && C:0 < 4 && D == 0
				PRINTFORML 「够了……胸前已被您揉得太过，在下快要忍不住了……」
			ENDIF
		ENDIF
	;二回目以降
	ELSEIF T:306 < 3 || FLAG:7 == 2
		;Ｂ系用　現在のパラで口上を分岐する
		;痛くて感じる余裕が無い&受虐狂ではない
		IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
			PRINTFORML 「……%CSTR:3%的手劲，未免太不知轻重。」
		;Ｂ責めメインの時
		ELSEIF C:4 == 1 || (C:4 == 2 && (PALAM:3 + UP:3) >= (PALAM:1 + UP:1) && (PALAM:3 + UP:3) >= (PALAM:2 + UP:2) && (PALAM:3 + UP:3) >= (PALAM:0 + UP:0) && C:3 > 0) && D == 0
			;殆どか、あまり感じていない
			IF (PALAM:3 + UP:3) < 500
				PRINTFORML 「……若只是想看在下窘迫，您已做得很够了。」
			;少し感じ始めたか、感じてきている
			ELSEIF (PALAM:3 + UP:3) < 3000
				PRINTFORML 「唔……别在那处反复捻弄，实在太磨人了。」
			;感じている
			ELSE
				PRINTFORML 「……胸口都快被您玩成另一张会说话的嘴了，尽会泄露在下的失态。」
			ENDIF
		;Ｂだけ绝顶寸前
		ELSEIF C:3 == 4 && C:1 < 4 && C:2 < 4 && C:0 < 4 && D == 0
