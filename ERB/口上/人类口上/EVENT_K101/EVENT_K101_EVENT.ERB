@KOJO_MESSAGE_EVENT_K101
;書きかえたい場所の「（基本の地の文を显示）」を消して変えてもいいです
;表示される基本の地の文はEVENT_M_EVENT.ERB、を参照して下さい
;TFLAG:13に入ってる数字イコール@EVENT_MESSAGE_XXのXXです。
;まだテンプレが無いイベントの口上を書く場合は最初に　IF TFLAG:13 == XX　というように書いてください
;-------------------------------------------------
;调教後百合プ雷
;-------------------------------------------------
IF TFLAG:13 == 4

	;贞操对和服腰带あり
	IF TEQUIP:2 == 5
		PRINTFORML 「……连这东西也不肯放过么。」
		PRINTFORMW 「%CSTR:3%将礼法、廉耻与防线一并锁在这细环之上，倒真是打得一手好算盘。」
	ELSE
		;初めて
		IF CFLAG:264 == 0
			PRINTFORMW 「……竟要在调教之后，再命在下去侍奉别的女子？」
			PRINTFORMW 「此等荒唐之事，若传回颍川，只怕族中长辈都要气得从地下起身斥我不肖。」
			PRINTFORMW 「……罢了。既然%CSTR:3%偏要看在下失仪，那在下也只能记下这一笔。」
			CFLAG:264 = 1
		;それ以外
		ELSEIF CFLAG:264 < 1 || FLAG:7 == 2
			PRINTFORMW 「又是这般安排么……%CSTR:3%还真当在下已能对这等事习以为常了。」
			PRINTFORMW 「只是，事到如今再谈体面，未免显得在下比您还要不识时务。」
			CFLAG:264 = 1
		ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;强精神药の反動
;-------------------------------------------------
IF TFLAG:13 == 6

	IF CFLAG:266 < 1 || FLAG:7 == 2
		PRINTFORMW 「……头脑像是被烈火反复燎过一般，连思绪都聚不起来。」
		PRINTFORMW 「%CSTR:3%给在下用的，究竟是药，还是专为摧折人心所备的刑具？」
		PRINTFORMW %CALLNAME:TARGET%抬手按着额角，素来清明的眼底难得露出近乎狼狈的混乱。
		CFLAG:266 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;调教後搾乳
;-------------------------------------------------
IF TFLAG:13 == 7

	IF CFLAG:267 < 1 || FLAG:7 == 2
		PRINTFORMW 「……竟、竟还会有这种用途？」
		PRINTFORMW %CALLNAME:TARGET%低头看着自己胸前残留的痕迹，神情里混杂着羞耻与难以言说的茫然。
		PRINTFORMW 「若连身体都被您驯养到这一步，在下往后还有什么资格自称清正自持……」
		CFLAG:267 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;调教後自慰
;-------------------------------------------------
IF TFLAG:13 == 8

	;贞操对和服腰带あり
	IF TEQUIP:2 == 5
		PRINTFORML 「……都被束到这般地步了，%CSTR:3%竟还嫌不够么。」
	ELSE
		IF CFLAG:268 < 1 || FLAG:7 == 2
			PRINTFORMW 「命在下自行抚慰……呵，%CSTR:3%如今连旁观在下失态，都能当作一桩消遣了。」
			PRINTFORMW 「只是这种事，纵然照做，也绝不意味着在下已将羞耻二字忘了个干净。」
			CFLAG:268 = 1
		ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;黄色のキャンディ使用時
;-------------------------------------------------
IF TFLAG:13 == 10

	IF CFLAG:270 < 1 || FLAG:7 == 2
		PRINTFORMW 「……甜得过了头，反倒叫人心里发慌。」
		PRINTFORMW 「%CSTR:3%总喜欢将药性、欲念与试探藏在这些看似无害的小东西里，真叫人防不胜防。」
		CFLAG:270 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;怀孕発覚時
;-------------------------------------------------
IF TFLAG:13 == 11
	SIF CFLAG:271 >= 1 && FLAG:7 != 2
		RETURN 0

	PRINTFORMW 「……有孕？」
	PRINTFORMW %CALLNAME:TARGET%像是怔住了一般，半晌都没能说出下一句话。
	PRINTFORMW 「这可真是……比任何筹谋都更不讲道理的一步棋。」
	PRINTFORMW 「%CSTR:3%既已将在下逼到这般地步，往后这孩子该如何安置，想来也不会容在下一人做主了吧。」
	CFLAG:271 = 1
ENDIF

;-------------------------------------------------
;分娩時
;-------------------------------------------------
IF TFLAG:13 == 12

	IF CFLAG:272 < 1 || FLAG:7 == 2
		PRINTFORMW 「呃……哈……这等痛楚，竟比受刑时还要绵长难熬……！」
		PRINTFORMW %CALLNAME:TARGET%死死攥着被褥，连素来端整的吐息都被剧痛撕得断断续续。
		PRINTFORMW 「……孩子既已要来到世上，便别让他也见着在下这副狼狈模样了……」
		CFLAG:272 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;育児室
;-------------------------------------------------
IF TFLAG:13 == 13

	;分娩前
	IF TALENT:153
		IF CFLAG:273 < 1 || FLAG:7 == 2
			PRINTFORMW 「……这里，便是之后抚育孩子的地方么。」
			PRINTFORMW 「原先总觉得这等事离在下甚远，如今真正站到这里，反倒有些不敢细想了。」
			CFLAG:273 = 1
		ENDIF
	;分娩後
	ELSE
		IF CFLAG:273 < 3 || FLAG:7 == 2
			PRINTFORMW 「……这孩子倒是安静，眉眼之间竟也已有几分神采。」
			PRINTFORMW %CALLNAME:TARGET%俯身替孩子拢好襁褓，动作里带着少见的柔和。
			PRINTFORMW 「若他日后当真能平平安安长大，那在下此前受过的种种，便也算不全然没有意义。」
			CFLAG:273 = 3
		ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;親離れ時
;-------------------------------------------------
IF TFLAG:13 == 14

	IF CFLAG:274 < 1 || FLAG:7 == 2
		PRINTFORMW 「……已经到该放手的时候了么。」
		PRINTFORMW 「为人父母者，总不能永远将孩子护在羽翼之下；此理在下懂得，只是……终究还是会挂念。」
		CFLAG:274 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;拍卖時
;-------------------------------------------------
IF TFLAG:13 == 18
    PRINTL
    PRINTL
    PRINTL
	;反抗刻印Lv3
	IF MARK:3 == 3
		PRINTFORMW 「原来如此。您终究还是决定，将在下像一件旧物般转手了。」
		PRINTFORMW 「也好。既已无话可说，在下便不劳您再多费心。」
		PRINTFORMW %CALLNAME:TARGET%神情冷淡地整了整衣襟，头也不回地跟着商人离开。
	;それ以外
	ELSE
		IF TALENT:病娇
            PRINTFORMW 「拍卖？把在下……不，把属于您的东西交给别人？」
            PRINTFORMW 「%MASTERNAME%，这种玩笑可一点也不好笑。」
            PRINTFORMW 直到被人强行拽开，%CALLNAME:TARGET%仍死死盯着%PLAYER_NAME()%，像是想从那张脸上剜出一个答案。
        ELSEIF TALENT:崩溃 || TALENT:疯癫
        	PRINTFORMW 「不是这样的……%MASTERNAME%不会不要在下，您们都在说谎……」
        	PRINTFORMW %CALLNAME:TARGET%失神地摇着头，最后被商人和护卫半拖半拽地带走了。
        ELSEIF TALENT:恋慕 || TALENT:相亲相爱
			PRINTFORMW 「……是么，原来您也会有把在下推出门外的一日。」
			PRINTFORMW 「起初在下还以为，纵使身份荒唐，至少这份心意可以换来片刻停留。」
			PRINTFORMW %CALLNAME:TARGET%勉强露出一个极浅的笑，抬手轻轻抚过%PLAYER_NAME()%的袖口。
			PRINTFORMW 「若这便是您的决定，在下不再失仪纠缠。」
			PRINTFORMW 「只是从今往后，还请偶尔也想起……曾有一人，真心实意地将自己的一切都托付给您。」
			PRINTFORMW 说完，%CALLNAME:TARGET%俯首行了一礼，随着商人离去。
        ELSEIF TALENT:服从 || TALENT:隶属
			PRINTFORMW 「您的命令，是要在下改侍奉别的人么？」
			PRINTFORMW %CALLNAME:TARGET%怔了片刻，最终还是低下头，顺从地应了一声。
			PRINTFORMW 「……明白了。既是您的意思，在下照做便是。」
        ELSEIF TALENT:淫乱 || TALENT:娼妇
			PRINTFORMW 「要把在下卖掉？呵……看来您是当真玩腻了。」
			PRINTFORMW 「也罢。只是等在下到了别处，若被别人用得更顺手些，您可别后悔。」
			PRINTFORMW %CALLNAME:TARGET%笑着跟商人离开，那笑意却始终未达眼底。
        ELSE
			PRINTFORMW 「……终究还是走到了这一步。」
			PRINTFORMW 「那便如此吧。只愿下一位主人，不必像您这般执拗得令人难堪。」
        ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;ビデオ拍卖時
;-------------------------------------------------
IF TFLAG:13 == 19

	IF CFLAG:278 < 1 || FLAG:7 == 2
		IF TALENT:恋慕 || TALENT:相亲相爱
			PRINTFORMW 「连这等影像也要拿去兜售么……您当真不肯替在下留半分体面。」
		ELSEIF TALENT:淫乱 || TALENT:娼妇
			PRINTFORMW 「呵，原来在下这副失态模样，还值得拿去给旁人助兴？」
		ELSEIF TALENT:服从 || TALENT:隶属
			PRINTFORMW 「若这样做能令您获利，在下并无异议。」
		ELSE
			PRINTFORMW 「竟连这等东西也不肯私藏，非要昭示于人前……未免太恶劣了。」
		ENDIF
		CFLAG:278 = 1
	ENDIF
ENDIF

;-------------------------------------------------
;衣服变更時 CFLAG:283（を適当に適用） 
;T:A = Y　　　　着脱する衣服を限定する時
;A = X　　　　　着脱部位全体を示す時
;TEQUIP:A = Y　 今何を着ているか（着てない場合は0）
;を組み合わせます。分かりにくくてスマン。
;-------------------------------------------------
IF TFLAG:13 == 25

	;脱がしたときの口上
	IF  Y == 0 && CFLAG:283 == 0 || FLAG:7 == 2
		;贞操带取下
		IF A == 2 && T:2 == 5
			PRINTFORMW 「……总算肯解开了么。」
			PRINTFORMW 「明明束缚的是身体，可被这东西磨损得最厉害的，偏偏像是人的心气。」
		;贞操带以外の下着取下
		ELSEIF A == 2
			PRINTFORMW 「%CSTR:3%剥人衣物时，倒总是一副理所当然的样子。」
			PRINTFORMW 「……罢了。横竖在您面前，在下也早没剩下多少可遮掩的体面。」
		ENDIF
		CFLAG:283 = 1
	;着せた時の口上
	ELSEIF CFLAG:283 < 2 || FLAG:7 == 2
		;女装：男性キャラ
		IF (TALENT:137 || TALENT:140) && (T:1 == 4 || T:1 == 6 || T:2 == 1 || T:2 == 4 || T:2 == 6 || T:3 == 1 || T:3 == 2 || T:4 == 1 || T:4 == 6 || T:6 == 2 || T:6 == 3 || T:6 == 4 || T:6 == 6 || T:6 == 9 || T:6 == 10 || T:9 == 9)
			PRINTFORML 「……连这等装束都备下了，%CSTR:3%对折辱人的手段，确实称得上思虑周全。」
		ENDIF
		;贞操带施錠
		IF T:2 == 5
			PRINTFORML 「咔哒一声轻响，倒像是连在下最后一点侥幸也一并锁死了。」
		ENDIF
		CFLAG:283 = 2
	ENDIF
ENDIF

;-------------------------------------------------
;朝料理イベント時 CFLAG:284 を、使用できるように確保してみる
;書きかえたい場所の「」を消してごっそり変えてもいいかも
;表示される基本の地の文はEVENT_M.ERBを参照にして下さい
;-------------------------------------------------
IF TFLAG:13 == 26
	;最初から弁当を食べる時
	IF K == 1

		PRINTFORMW 「既然已经送到眼前，弃之未免可惜。」
		PRINTFORMW 「只是%CSTR:3%若指望在下因此感激涕零，那恐怕要让您失望了。」
	;売るのをやめて食べる時
	ELSEIF K == 2

		PRINTFORMW 「……临到头又改了主意？」
		PRINTFORMW 「也好。比起任人标价贩卖，一顿尚有余温的饭，总归更像是给活人准备的东西。」
	;主人が弁当を作るとき
	ELSEIF K == 3

		PRINTFORMW 「您亲自下厨？」
		PRINTFORMW 「这倒是罕见。若味道尚可，在下或许会勉强称赞一句……当然，只一句。」
	;食後の運動(性的な意味で)直前
	ELSEIF K == 4

		PRINTFORMW 「……原来所谓‘饭后活动’，指的是这个。」
		PRINTFORMW 「%CSTR:3%还真是半点都不肯把心思用在正经处。」
	;毒を盛られた
	ELSEIF K == 5

		PRINTFORMW 「……味道不对。」
		PRINTFORMW %CALLNAME:TARGET%放下手中的食物，抬眼望向对方时，眸色已渐渐沉了下来。
		PRINTFORMW 「下毒这种手段，未免太下作。可惜，手法尚嫌粗浅，瞒不过在下。」
	;毒を見抜いたので弱みを握るイベント（相性のいい子に食べさせるver）
	ELSEIF K == 6

		PRINTFORMW 「既已做下这种事，便该知道留下了多大的把柄。」
		PRINTFORMW 「放心，在下暂且不会声张……至于之后要如何补偿，就看你自己的诚意了。」
	;毒を見抜いたので弱みを握るイベント（問い詰めるver）
	ELSEIF K == 7

		PRINTFORMW 「说吧。是谁指使你的，还是你自己起了害人的心思？」
		PRINTFORMW 「若此刻仍想着狡辩，那在下便只能把这件事按最坏的情形处置了。」
	;毒殺された
	ELSEIF K == 8

		PRINTFORMW 「……原来如此，终究还是防漏了一手么……」
		PRINTFORMW 「只可惜，竟是以这般难堪的方式收场……%MASTERNAME%，您可莫要忘了，在下原本还能替您筹划更多。」
	ENDIF
ENDIF

