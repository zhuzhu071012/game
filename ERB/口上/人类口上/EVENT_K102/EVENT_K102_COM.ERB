	CALL TRAIN_MESSAGE
	;今回は汎用状況説明文を表示させたくない場合：共通の地の文を呼び出す前にTFLAG:52 = 1と付け加える
	IF T:302 == 1
		;初めてこの指令を選んだ時
		IF CFLAG:302 == 0
			PRINTFORML 「竟要嘉以口舌侍奉……阁下当真是连最后一点颜面也不肯留。」
			PRINTFORMW %CALLNAME%说完这句话后，仍旧难掩屈辱地别开了目光。
			RETURN 0
		;もう選んだことあるが、今回の调教では初めてこの指令を選んだ時
		ELSE
			IF TALENT:恋慕 || TALENT:相亲相爱
				PRINTFORML 「……请别那样盯着看。嘉会照做，只是……容嘉稍稍整顿一下心绪。」
				RETURN 0
			ENDIF
			;Ｃ系用　現在のパラで口上を分岐する
			;痛くて感じる余裕が無い&受虐狂ではない
			IF D >= 1 && C:4 <= 2 && TALENT:84 != 1 && ABL:9 < 3
			;Ｃ責めメインの時
			ELSEIF C:4 == 1 || (C:4 == 2 && PALAM_COMPARE(0) && C:0 > 0) && D == 0
				;殆どか、あまり感じていない
				IF (PALAM:0 + UP:0) < 500
				;少し感じ始めたか、感じてきている
				ELSEIF (PALAM:0 + UP:0) < 3000
				;感じている
				ELSE
				ENDIF
			;Ｃだけ绝顶寸前
			ELSEIF C:0 == 4 && C:1 < 4 && C:2 < 4 && C:3 < 4 && D == 0
			ENDIF
		ENDIF
	;今回の调教で二回目以降
	ELSEIF T:302 < 3 || FLAG:7 == 2
	ENDIF
