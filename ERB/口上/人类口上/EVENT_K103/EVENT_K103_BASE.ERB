@EVENTTRAIN
;オプションで口上をオフした時は駄目
SIF FLAG:7 <= 0
	RETURN 0
SIF NO:TARGET != 103
	RETURN 0
@KOJO_EVENTTRAIN_K103
;--------------------------------------------------
;特定助手時に特殊助手口上を呼び出す(Y1を助手との関係设定(CFLAG:2000～2100)の値に置換）
