;ENDIF
;-------------------------------------------------
;调教開始時（一回のみの台詞） CFLAG201
;-------------------------------------------------
DRAWLINE
SIF CFLAG:201 == 6
	RETURN 0
;初调教時
IF CFLAG:201 == 0
	PRINTFORMW 进门时，%CALLNAME%已安静端坐在榻旁，神情恭谨得滴水不漏。
	PRINTFORMW 「……%CSTR:3%。」
	PRINTFORMW 「%CSTR:0%替您谋事，便是看得出，您的势最稳。」
	PRINTFORMW 「可如今您把%CSTR:0%锁在这里……是怀疑%CSTR:0%生了异心，还是另有筹谋？」
	PRINTFORMW %PLAYER_NAME()%大笑。
	PRINTFORMW 「文和，所有人里只有你能理解我。」
	PRINTFORMW 「若能成事，此中曲折，是非公道，又何必管他人如何评说。」
	PRINTFORMW %CALLNAME%轻轻尝试挣脱，发现链条被牢牢锁在床上。
	PRINTFORMW 「……虽然不明白%CSTR:3%您要做什么，但%CSTR:0%已经无法改变您的想法了，是吗？」
	PRINTFORMW  %CALLNAME%垂下眼眸，主动脱下了外衫。
	CFLAG:201 = 1
	RETURN 0
;恋慕陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:3) || (CFLAG:201 < 6 && TALENT:6)
	IF CFLAG:201 < 5 && TALENT:恋慕
		PRINTFORMW 「……近来%CSTR:0%每回听见您的脚步声，总会先想，今夜是福是祸。」
		PRINTFORMW 「可真等您走近了，乱起来的偏偏不是算计，而是这颗越来越不肯安分的心。」
		PRINTFORMW 「若说最初还能劝自己只是权宜之计，如今这份惦念，连%CSTR:0%自己都快搪塞不过去了……」
		PRINTFORMW %CALLNAME%垂下眼睫，像是在强压住胸中翻涌的情绪。
		PRINTFORMW 「所以，至少这一刻……请别把%CSTR:0%只当作解闷的器物。」
		PRINTFORMW 「您若肯看着%CSTR:0%，哪怕只多看一眼，%CSTR:0%大概都会当成赚来的。」
		CFLAG:201 = 5
		RETURN 0
	;相亲相爱
	ELSEIF CFLAG:201 < 6 && TALENT:相亲相爱
		PRINTFORMW 「若您执意要%CSTR:0%坦白，那%CSTR:0%便不再绕弯子了。」
		PRINTFORMW 「%CSTR:0%这一生最擅长的，本该是把话藏三分，把心思收七分。偏偏到了您这里，越想收，越像自欺。」
		PRINTFORMW 「什么利害、什么分寸，如今都压不过想留在您身边这一念。」
		PRINTFORMW %CALLNAME%抬起头，目光里不再有回避，只剩下不容错认的深切情意。
		PRINTFORMW 「%CSTR:0%心悦您，且甘之如饴。」
		PRINTFORMW 「所以，请别再逼%CSTR:0%装作无事了……只要您伸手，%CSTR:0%便会过去。」
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;淫乱陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:4) || (CFLAG:201 < 6 && TALENT:7)
	IF CFLAG:201 < 5 && TALENT:淫乱
		PRINTFORMW 「……不知从何时起，最会坏事的已不是旁人的刀，而是%CSTR:0%这副越来越不听话的身子。」
		PRINTFORMW 「越明白不该沉进去，它越会在您靠近时先一步发热，像是存心叫%CSTR:0%失算。」
		PRINTFORMW 「这等失序与放纵，本该早早掐断……可如今，先低头的偏偏总是身体。」
		PRINTFORMW %CALLNAME%抬手掩住半张脸，耳根却早已透出情欲的热意。
		PRINTFORMW 「若您今日还要继续，%CSTR:0%……大概已不会再做那种徒劳的挣扎了。」
		CFLAG:201 = 5
		RETURN 0
	;娼妇
	ELSEIF CFLAG:201 < 6 && TALENT:娼妇
		PRINTFORMW 「%MASTERNAME%，您终于来了。」
		PRINTFORMW 「%CSTR:0%已等得太久，久到连呼吸都像是悬在火上。」
		PRINTFORMW 「您看，只消想到您会如何碰%CSTR:0%，这副不争气的身体便自己先乱了。」
		PRINTFORMW %CALLNAME%主动握住%PLAYER_NAME()%的手，贴向自己滚烫的身体，目光潮湿而失焦。
		PRINTFORMW 「机心、分寸、文和这点名声……若都要拿去换您一次垂怜，%CSTR:0%便一并奉上。」
		PRINTFORMW 「所以，别再叫%CSTR:0%继续等了。今日想怎样用%CSTR:0%，都请尽兴。」
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;服从陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:5) || (CFLAG:201 < 6 && TALENT:8)
	IF CFLAG:201 < 5 && TALENT:服从
		PRINTFORMW 「……%CSTR:0%似乎终于想明白了。」
		PRINTFORMW 「您要的，从来不是辩驳，也不是硬撑，而是一个会按您心意低头的人。」
		PRINTFORMW 「既然争到最后也换不来半分宽宥，那不如顺着您，至少还能求个安稳。」
		PRINTFORMW %CALLNAME%深吸了一口气，像是将最后一点固执也一并吞咽下去。
		PRINTFORMW 「那么，从今日起……只要是您的命令，%CSTR:0%会学着照做。」
		CFLAG:201 = 5
		RETURN 0
	ELSEIF CFLAG:201 < 6 && TALENT:隶属
		PRINTFORMW 「……能为您所用，已是%CSTR:0%如今唯一值得庆幸之事。」
		PRINTFORMW 「被您约束、被您命令、被您亲手磨成更顺手的模样……这些竟会令人安心到如此地步。」
		PRINTFORMW %CALLNAME%缓缓垂首，温顺地将额头抵在%PLAYER_NAME()%手背上。
		PRINTFORMW 「若您愿意，%CSTR:0%愿以余生侍奉您的欲望与喜怒。」
		PRINTFORMW 「只求您莫要弃置%CSTR:0%……%CALLNAME:MASTER%大人。」
		MASTERNAME = %CALLNAME:MASTER%大人
		;口調が敬語タイプになる
		CFLAG:601 = 2
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;初めて屈服刻印Lv1になった
ELSEIF CFLAG:201 < 2 && MARK:2 == 1
	PRINTFORMW 「……原以为不过是皮肉之苦，%CSTR:0%尚能守心不乱。」
	PRINTFORMW 「可如今看来，真正令人作呕的，倒不是疼痛本身，而是身体竟会开始记住这种屈辱。」
	CFLAG:201 = 2
	RETURN 0
;初めて屈服刻印Lv2になった
ELSEIF CFLAG:201 < 3 && MARK:2 == 2
	PRINTFORMW 「被逼得渐渐习惯，竟比单纯受刑更难堪……」
	PRINTFORMW 「%CSTR:3%若是想看%CSTR:0%一步步失算，倒确实做到了。」
	CFLAG:201 = 3
	RETURN 0
;初めて屈服刻印Lv3になった
ELSEIF CFLAG:201 < 4 && MARK:2 == 3
	PRINTFORMW 「……若连羞耻与抗拒都被磨得所剩无几，%CSTR:3%才算满意么？」
	PRINTFORMW 「好吧。至少在这间屋子里，%CSTR:0%已无力再同您争论谁是谁非了。」
	CFLAG:201 = 4
	RETURN 0
ENDIF

