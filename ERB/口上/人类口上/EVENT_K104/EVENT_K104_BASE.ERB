;?? ????
;调教前和调教後的台詞
;-------------------------------------------------
;eraQueenA用口上模板
;口上を書けた部分の「CFLAG:2XX = 1」や「CFLAG:2XX = 2」のコメントアウトは解除してください。
;-------------------------------------------------
;--------------------------------------------------
;口上文件的存在判定
;--------------------------------------------------
@EVENTSHOP
#PRI
FLAG:104 = 1
SIF FLAG:7 == 0
	FLAG:7 = 1
;--------------------------------------------------
;EVENTTRAIN关系
;调教開始時的台词 CFLAG 201～219を使用
;--------------------------------------------------
@EVENTTRAIN
;オプションで口上をオフした時は駄目
SIF FLAG:7 <= 0
	RETURN 0
SIF NO:TARGET != 104
	RETURN 0
@KOJO_EVENTTRAIN_K104
;--------------------------------------------------
;特定助手時に特殊助手口上を呼び出す(Y1を助手との関係设定(CFLAG:2000～2100)の値に置換）
;--------------------------------------------------
;IF ASSI > 0 && ASSIPLAY
;	IF CFLAG:(NO:ASSI + 2000) == Y1
;		CALL EVENTTRAIN_PY1
;		RETURN 0
;	ENDIF
;ENDIF
;--------------------------------------------------
;簡易助手口上の発動時に初调教時口上をスキップ（Y1を助手のキャラ性格番号にする）
;複数人いる際には、SIF CFLAG:(NO:ASSI + 2000) == Y1 || CFLAG:(NO:ASSI + 2000) == Z1と追加していく
;初调教時口上をスキップしない場合は使わなくてもいい
;--------------------------------------------------
;IF CFLAG:201 == 0 && ASSI > 0
;	SIF CFLAG:(NO:ASSI + 2000) == Y1
;		CFLAG:201 =1
;ENDIF
;-------------------------------------------------
;调教開始時（一回のみの台詞） CFLAG201
;-------------------------------------------------
DRAWLINE
SIF CFLAG:201 == 6
	RETURN 0
;初调教時
IF CFLAG:201 == 0
	PRINTFORMW 进门时，%CALLNAME%坐得笔直，脸色阴沉，目光里既有屈辱，也有被强压住的野心。
	PRINTFORMW 「……父亲竟亲自来了。」
	PRINTFORMW 「我原以为，您会用朝堂与兵权来磨我，却没想到会把我锁到这种地方。」
	PRINTFORMW 「您这是在考验我，还是要亲手把我驯成只能仰您鼻息的儿子？」
	PRINTFORMW %PLAYER_NAME()%没有回答，只抬手托起了%CALLNAME%的下颌。
	PRINTFORMW 那双总不肯轻易示弱的眼睛仍倔强地盯着%PLAYER_NAME()%，却终究漏出了一丝狼狈。
	PRINTFORMW 「……若这就是您的手段，那我记住了。」
	PRINTFORMW 「只是到最后，被逼着低头的人究竟是谁，还未可知。」
	CFLAG:201 = 1
	RETURN 0
;恋慕陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:3) || (CFLAG:201 < 6 && TALENT:6)
	IF CFLAG:201 < 5 && TALENT:恋慕
		PRINTFORMW 「……近来我每次听见您的脚步声，心绪都会先乱上一分。」
		PRINTFORMW 「明知这般动摇极失分寸，却还是会忍不住去想，今日您会不会比昨日多看我一眼。」
		PRINTFORMW 「若说最初是厌怒与不甘，如今那份心思，早已变得连我自己都无法辩驳了……」
		PRINTFORMW %CALLNAME%垂下眼睫，像是在强压住胸中翻涌的情绪。
		PRINTFORMW 「所以，至少此刻……请别把我只当作供您取乐的器物。」
		PRINTFORMW 「哪怕只是一瞬也好，请您看着我，把我当作真正活着的人。」
		CFLAG:201 = 5
		RETURN 0
	;相亲相爱
	ELSEIF CFLAG:201 < 6 && TALENT:相亲相爱
		PRINTFORMW 「若您执意要我坦白，那我便不再隐瞒了。」
		PRINTFORMW 「尊严、家声、前程、是非……这些曾被我看得极重的东西，如今竟都敌不过想留在您身边这一念。」
		PRINTFORMW 「荒唐也好，失礼也罢，我已经无心再与自己争辩。」
		PRINTFORMW %CALLNAME%抬起头，目光里不再有回避，只剩下不容错认的深切情意。
		PRINTFORMW 「我心悦您，且甘之如饴。」
		PRINTFORMW 「所以，请不要再试探我的真心了……只要您伸手，我便会过去。」
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;淫乱陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:4) || (CFLAG:201 < 6 && TALENT:7)
	IF CFLAG:201 < 5 && TALENT:淫乱
		PRINTFORMW 「……不知是从何时起，我已无法再单纯将此视作折辱了。」
		PRINTFORMW 「越是明白其中有违父子伦常，身体便越是会在您靠近时先一步发热。」
		PRINTFORMW 「这等失序与放纵，本该由我亲手斩断……可如今，最先屈服的偏偏是这具身体。」
		PRINTFORMW %CALLNAME%抬手掩住半张脸，耳根却早已透出情欲的热意。
		PRINTFORMW 「若您今日仍要继续，我……大概已不会像先前那样徒劳地抗拒了。」
		CFLAG:201 = 5
		RETURN 0
	;娼妇
	ELSEIF CFLAG:201 < 6 && TALENT:娼妇
		PRINTFORMW 「%MASTERNAME%，您终于来了。」
		PRINTFORMW 「我已等得太久，久到连呼吸都像是悬在火上。」
		PRINTFORMW 「您看，只消想到您会如何碰我，这副不争气的身体便自己先乱了。」
		PRINTFORMW %CALLNAME%主动握住%PLAYER_NAME()%的手，贴向自己滚烫的身体，目光潮湿而失焦。
		PRINTFORMW 「储位、尊严、野心、子桓之名……若都要拿去换您一次垂怜，那我便把它们都押上。」
		PRINTFORMW 「所以，别再叫我继续等了。今日想怎样用我，都请尽兴。」
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;服从陷落ルート
ELSEIF (CFLAG:201 < 5 && TALENT:5) || (CFLAG:201 < 6 && TALENT:8)
	IF CFLAG:201 < 5 && TALENT:服从
		PRINTFORMW 「……我似乎终于明白了。」
		PRINTFORMW 「您所求的，从来都不是辩驳、也不是反抗，而是一个会按您心意俯首的人。」
		PRINTFORMW 「若事到如今仍执着于那些无用的争论，也不过是让自己更加狼狈罢了。」
		PRINTFORMW %CALLNAME%深吸了一口气，像是将最后一点固执也一并吞咽下去。
		PRINTFORMW 「那么，从今日起……只要是您的命令，我会学着照做。」
		CFLAG:201 = 5
		RETURN 0
	ELSEIF CFLAG:201 < 6 && TALENT:隶属
		PRINTFORMW 「……能为您所用，已是我如今唯一值得庆幸之事。」
		PRINTFORMW 「被您约束、被您命令、被您亲手打磨成更顺手的模样……这些竟会令人安心到如此地步。」
		PRINTFORMW %CALLNAME%缓缓垂首，温顺地将额头抵在%PLAYER_NAME()%手背上。
		PRINTFORMW 「若您愿意，我愿以余生侍奉您的欲望与喜怒。」
		PRINTFORMW 「只求您莫要弃置我……%CALLNAME:MASTER%大人。」
		MASTERNAME = %CALLNAME:MASTER%大人
		;口調が敬語タイプになる
		CFLAG:601 = 2
		CFLAG:201 = 6
		RETURN 0
	ENDIF
;初めて屈服刻印Lv1になった
ELSEIF CFLAG:201 < 2 && MARK:2 == 1
	PRINTFORMW 「……原以为不过是皮肉之苦，我尚能守心不乱。」
	PRINTFORMW 「可如今看来，真正令人作呕的，倒不是疼痛本身，而是身体竟会开始记住这种屈辱。」
	CFLAG:201 = 2
	RETURN 0
;初めて屈服刻印Lv2になった
ELSEIF CFLAG:201 < 3 && MARK:2 == 2
	PRINTFORMW 「被逼得渐渐习惯，竟比单纯受刑更难堪……」
	PRINTFORMW 「阁下若是想看我自乱阵脚，倒确实做到了。」
	CFLAG:201 = 3
	RETURN 0
;初めて屈服刻印Lv3になった
ELSEIF CFLAG:201 < 4 && MARK:2 == 3
	PRINTFORMW 「……若连羞耻与抗拒都被磨得所剩无几，阁下才算满意么？」
	PRINTFORMW 「好吧。至少在这间屋子里，我已无力再同您争论谁是谁非了。」
	CFLAG:201 = 4
	RETURN 0
ENDIF

;-------------------------------------------------
;簡易助手口上（Y1を助手との関係设定の値に置換)
;-------------------------------------------------
;助手の有無をチェック（いない場合は二回目以降へ飛ぶ）
IF ASSI < 0 
	CALL EVENTTRAIN_SECOND_K104
;例:助手が调教对象の兄の場合（CFLAG:(NO:ASSI + 2000)を1に设定）
;ELSEIF CFLAG:(NO:ASSI + 2000) == 1
;	;初めて
;	IF CFLAG:(NO:ASSI + 700) == 0
;		PRINTFORMW 
;		CFLAG:(NO:ASSI + 700) = 1
	;二回目以降
;	ELSEIF CFLAG:(NO:ASSI + 700) < 2 || FLAG:7 ==2
;		PRINTFORMW 
;		CFLAG:(NO:ASSI + 700) = 2
;	ENDIF
;Y1を助手との関係设定の値に置換
