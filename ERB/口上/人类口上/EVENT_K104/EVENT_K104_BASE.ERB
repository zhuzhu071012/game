;-------------------------------------------------
;调教開始時（2回目以降、「一回だけ表示」に设定してなければ何度も显示台詞です）
;何度も显示わけなので、何種類かの短い台詞を用意したほうがいいかもしれません。
;毎回表示されたら面倒くさいかもしれないので、「一回だけ表示」に设定していれば、三分の一の確率で表示されることしました。
;-------------------------------------------------
@EVENTTRAIN_SECOND_K104

;反抗刻印Lv3が消された場合、「一回だけ表示」用のフラグを解除。
SIF MARK:反抗刻印 < 3 && CFLAG:202 == 4
	CFLAG:202 = 0
;反抗刻印Lv3（最初に反抗刻印Lv3をついた時のの場合）
IF MARK:反抗刻印 == 3 && CFLAG:202 < 4
	;PRINTFORML 
	;PRINTFORMW 
	;CFLAG:202 = 4
;反抗刻印Lv3、屈服刻印 < 2、顺从 <= 2　（毎回表示の場合）
ELSEIF MARK:反抗刻印 == 3 && MARK:屈服刻印 < 2 && ABL:顺从 <= 2 && (CFLAG:202 < 4 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	;随机で口上が変化する
	;随机で口上が変化する　!RAND:2→二分の一の確率、!RAND:3→三分の一の確率…以下同類
	;随机で三種類の台詞から選ぶ時は「IF !RAND:3 ～　ELSEIF !RAND:2 ～　ELSE」にすればＯＫ。
	IF !RAND:2
		;PRINTFORML 
		;PRINTFORMW 
	ELSE
		;PRINTFORML 
		;PRINTFORMW 
	ENDIF
	;CFLAG:202 = 4
;屈服刻印Lv0
;ELSEIF MARK:2 == 0 && (CFLAG:202 < 1 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
;	PRINTFORMW 
;	CFLAG:202 = 1
;屈服刻印Lv1以下
ELSEIF MARK:2 <= 1 && (CFLAG:202 < 2 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	IF !RAND:2
		PRINTFORML 「若只是想看我失态，阁下今日怕是又要失望了。」
	ELSE
		PRINTFORML 「礼坏乐崩，莫甚于此……阁下难道当真毫不在意么？」
	ENDIF
	CFLAG:202 = 2
;屈服刻印Lv2
ELSEIF MARK:2 == 2 && (CFLAG:202 < 3 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	IF !RAND:2
		PRINTFORML 「……阁下还真是执拗。竟连片刻喘息都不肯施舍。」
	ELSE
		PRINTFORML 「我若说厌了，阁下会停手么？……想来也不会。」
	ENDIF
	CFLAG:202 = 3
;屈服刻印Lv3＋陷落素質无
ELSEIF MARK:2 == 3 && !KANRAKU(TARGET) && (CFLAG:202 < 4 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	IF !RAND:2
		PRINTFORML 「若您只是想要顺从，那如今的我，应当已勉强算是合格了吧。」
	ELSE
		PRINTFORML 「……请快些吧。拖得越久，只会显得彼此都更难堪。」
	ENDIF
	CFLAG:202 = 4
;恋慕陷落ルート
ELSEIF (TALENT:3 || TALENT:6) && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	;恋慕
	IF TALENT:3 && (CFLAG:202 < 5 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)

		IF !RAND:2
			PRINTFORML 「来迟了，%MASTERNAME%。」
			PRINTFORMW 「我本想再读一卷静心，结果每翻一页，想到的却都是您。」
		ELSE
			PRINTFORML 「……明知您总会来，我还是会不自觉地提前等候。」
			PRINTFORMW 「这般心绪，实在有失分寸，却已不是我能轻易压下的了。」
		ENDIF
		CFLAG:202 = 5
	;相亲相爱
	ELSEIF TALENT:6 && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
			IF !RAND:2
				PRINTFORML 「今夜也请别让我等太久，%MASTERNAME%。我会想您。」
			ELSE
				PRINTFORML 「只要想到您会来，这间屋子便不再像牢笼，而像是我唯一愿意停留之地。」
			ENDIF
		CFLAG:202 = 6
	ENDIF
;淫乱陷落ルート
ELSEIF (TALENT:4 || TALENT:7) && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	IF TALENT:淫乱 && (CFLAG:202 < 5 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
		IF !RAND:2
			PRINTFORML 「……您总算来了。再迟一些，我怕是要自己熬不住了。」
		ELSE
			PRINTFORML 「今夜想从哪里开始？……我会比昨日更听话些。」
		ENDIF
		CFLAG:202 = 5
	ELSEIF TALENT:娼妇 && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
		IF !RAND:2
			PRINTFORML 「快些吧，%MASTERNAME%。我这副身子，已经从里到外都在想您了。」
		ELSE
			PRINTFORML 「若只是站在那里看着，我可是会不满的……请把我用到坏掉为止。」
		ENDIF
		CFLAG:202 = 6
	ENDIF
;服从陷落ルート
ELSEIF (TALENT:5 || TALENT:8) && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	IF TALENT:服从 && (CFLAG:202 < 5 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
		IF !RAND:2
			PRINTFORML 「您来了。那么，请下命吧。」
		ELSE
			PRINTFORML 「我已做好准备。无论今夜您想如何，都请明示。」
		ENDIF
		CFLAG:202 = 5
	;隶属
	ELSEIF TALENT:隶属 && (CFLAG:202 < 6 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
		IF !RAND:2
			PRINTFORML 「%CALLNAME:MASTER%大人，请尽情使用我。」
		ELSE
			PRINTFORML 「我已等候多时。只要是您的意思，我无不甘受。」
		ENDIF
		CFLAG:202 = 6
	ENDIF
ENDIF
RETURN 0

;-------------------------------------------------
;EVENTEND関係
;调教结束時のセリフ
;-------------------------------------------------
@EVENTEND
SIF FLAG:7 <= 0
	RETURN 0
SIF NO:TARGET != 104
	RETURN 0
@KOJO_EVENTEND_K104
;--------------------------------------------------
;调教结束時のセリフ
;--------------------------------------------------
;调教をすぐやめたときは口上を不显示
SIF PREVCOM == -1
	RETURN 0
DRAWLINE

;最初に反抗刻印Lv3を取った時（一回だけ）
IF MARK:3 == 3 && CFLAG:217 < 1
	;PRINTFORML 
	;PRINTFORMW 
	;CFLAG:217 = 1
;反抗刻印Lv3、屈服刻印 < 2、顺从 <= 2
ELSEIF MARK:反抗刻印 == 3 && MARK:屈服刻印 < 2 && ABL:顺从 <= 2 && (CFLAG:217 < 1 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	;PRINTFORML 
	;PRINTFORMW 
	;CFLAG:217 = 1
;屈服刻印Lv1以下
ELSEIF MARK:2 <= 1 && (CFLAG:219 < 1 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	PRINTFORMW 「若阁下还有半分清醒，便该明白——今日之举，终究不会有善果。」
	CFLAG:219 = 1
;屈服刻印Lv2
ELSEIF MARK:2 == 2 && (CFLAG:219 < 2 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	PRINTFORMW 「……至少今日，终于结束了么。」
	CFLAG:219 = 2
;屈服刻印Lv3＋陷落素質无
ELSEIF MARK:2 == 3 && !KANRAKU(TARGET) && (CFLAG:219 < 2 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	PRINTFORMW 「拖着这样的身体，还要若无其事地端坐……我如今倒也学会了。」
	CFLAG:219 = 3
;陷落済み＋体力500未満
ELSEIF KANRAKU(TARGET) && BASE:0 < 500 && (CFLAG:218 < 1 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	;恋慕陷落ルート
	IF (TALENT:3 || TALENT:6)
		PRINTFORMW 「……若您肯的话，扶我一把也好。我实在没多少力气再强撑颜面了。」
	;淫乱陷落ルート
	ELSEIF (TALENT:4 || TALENT:7)
		PRINTFORMW 「哈……终于肯停下了么。可我这副身子，反倒还在念着您留下的热意。」
	;服从陷落ルート
	ELSEIF (TALENT:5 || TALENT:8)
		PRINTFORMW 「命令也好、责罚也罢……至少今夜，我已无力再多承一分了。」
	ENDIF
	CFLAG:218 = 1
;陷落済み
ELSEIF KANRAKU(TARGET) && (CFLAG:219 < 4 || (FLAG:7 == 1 && !RAND:3) || FLAG:7 == 2)
	;恋慕陷落ルート
	IF (TALENT:3 || TALENT:6)
		PRINTFORMW 「夜深了，%MASTERNAME%。若您愿意，再多留片刻……我会很高兴。」
	;淫乱陷落ルート
	ELSEIF (TALENT:4 || TALENT:7)
		PRINTFORMW 「若您今夜就此离开，我多半会在床上辗转许久，怎么都静不下来。」
	;服从陷落ルート
	ELSEIF (TALENT:5 || TALENT:8)
		PRINTFORMW 「您若已满意，我便在此恭送。明日若还需要，我会如常候着。」
		
	ENDIF
	CFLAG:219 = 4
ENDIF
DRAWLINE
RETURN 0

